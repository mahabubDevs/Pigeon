generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ------------------- User & Admin -------------------
model User {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  username      String           @unique
  email         String           @unique
  phone         String?
  password      String
  role          Role?            @relation(fields: [roleId], references: [id])
  roleId        String?          @db.ObjectId
  status        String           @default("active") // active, inactive, banned
  subscription  SubscriptionUser?
  pageAccess    String[]
  pigeons       Pigeon[]         @relation("UserPigeons")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  permissions String[]
  users       User[]
}

// ------------------- Pigeon -------------------
model Pigeon {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  ringNumber    String         @unique
  name          String?
  country       String?
  birthYear     Int?
  shortInfo     String?
  breeder       String?
  color         String?
  pattern       String?
  racerRating   Float?
  breederRating Float?
  gender        String?
  status        String?        @default("active")
  location      String?
  racingRating  Float?
  notes         String?
  photos        String[]
  fatherRing    String?
  motherRing    String?
  owner         User?          @relation("UserPigeons", fields: [ownerId], references: [id])
  ownerId       String?        @db.ObjectId
  results       RaceResult[]
  siblings      Sibling[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ------------------- Race Result -------------------
model RaceResult {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pigeon    Pigeon   @relation(fields: [pigeonId], references: [id])
  pigeonId  String   @db.ObjectId
  name      String
  date      DateTime
  distance  Float?
  totalBirds Int?
  place     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------- Sibling -------------------
model Sibling {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  pigeon       Pigeon   @relation(fields: [pigeonId], references: [id])
  pigeonId     String   @db.ObjectId
  name         String?
  siblingType  String?  // full, half
  ringNumber   String?
  birthYear    Int?
  qualityRacer Boolean?
  father       String?
  mother       String?
  gender       String?
  action       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ------------------- Subscription -------------------
model SubscriptionPlan {
  id               String              @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  shortDescription String?
  price            Float?             @default(0)
  duration         String?            // yearly, monthly, free
  fullDescription  String?
  users            SubscriptionUser[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model SubscriptionUser {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  user          User              @relation(fields: [userId], references: [id])
  userId        String            @unique @db.ObjectId
  plan          SubscriptionPlan  @relation(fields: [planId], references: [id])
  planId        String            @db.ObjectId
  startDate     DateTime          @default(now())
  endDate       DateTime?
}

// ------------------- Verified Breeder -------------------
model VerifiedBreeder {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  loftName       String
  breederName    String
  country        String?
  email          String?  @unique
  phone          String?
  experienceLevel String?
  gender         String?
  pigeonScore    Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
